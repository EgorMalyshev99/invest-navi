{
  "name": "@repo/ui",
  "version": "0.0.1",
  "private": true,
  "exports": {
    ".": {
      "react-server": "./src/server.ts",
      "default": "./src/index.ts"
    },
    "./globals.css": "./src/globals.css",
    "./postcss.config": "./postcss.config.mjs",
    "./components/*": "./src/components/*.tsx",
