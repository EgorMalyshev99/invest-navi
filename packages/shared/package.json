{
  "name": "@repo/shared",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "pnpm build --watch",
    "build": "tsc -b -v",
    "lint": "eslint \"src/**/*.ts\"",
    "check-types": "tsc --noEmit"
  },
  "main": "./dist/entry.js",
  "types": "./dist/entry.d.ts",
  "files": [
    "./dist/**"
  ],
  "exports": {
    ".": {
      "types": "./dist/entry.d.ts",
      "import": "./dist/entry.js"
    },
    "./lib/*": {
      "types": "./dist/lib/*.d.ts",
      "import": "./dist/lib/*.js"
    }
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "eslint": "10.4.1",
    "@types/node": "^25.9.1",
    "typescript": "6.0.3"
  }
}
