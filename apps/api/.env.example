# ─── App origins (CORS + OAuth redirect allowlist) ───
LANDING_URL=http://localhost:3001
# Dashboard origin; OAuth callbacks are allowed only for this URL
DASHBOARD_URL=http://localhost:3003

# ─── Database ───
DATABASE_URL=postgresql://invest:invest_secret@localhost:5432/invest_navi

# ─── Auth tokens ───
JWT_SECRET=dev-access-secret
JWT_REFRESH_SECRET=dev-refresh-secret
JWT_EXPIRES_IN_SECONDS=900
JWT_REFRESH_EXPIRES_IN_SECONDS=604800
COOKIE_DOMAIN=
COOKIE_SECURE=false

# ─── AI providers (groq | gemini | openrouter) ───
AI_PROVIDER=groq
GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=


# Market data (MOEX ISS + T-Invest API)
MOEX_ISS_BASE_URL=https://iss.moex.com/iss
TINKOFF_INVEST_TOKEN=
TINKOFF_INVEST_API_URL=https://invest-public-api.tinkoff.ru/rest
MARKET_CACHE_TTL_SECONDS=60

# ─── OAuth providers ───
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
