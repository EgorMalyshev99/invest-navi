{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd ../.. && pnpm install",
  "buildCommand": "cd ../.. && pnpm --filter @repo/api build && pnpm --filter api build",
  "functions": {
    "dist/src/vercel.js": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "rewrites": [{ "source": "/(.*)", "destination": "/dist/src/vercel.js" }]
}
