{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd ../.. && pnpm install",
  "buildCommand": "cd ../.. && turbo run build --filter=dashboard",
  "outputDirectory": "dist",
  "framework": null,
  "rewrites": [
    {
      "source": "/((?!assets/|favicon\\.ico|favicons/|img/|manifest\\.webmanifest).*)",
      "destination": "/index.html"
    }
  ]
}
