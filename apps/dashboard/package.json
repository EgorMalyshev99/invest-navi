{
  "name": "dashboard",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "prebuild": "pnpm --filter @repo/api build",
    "build": "tsr generate && tsc -b && vite build",
    "preview": "vite preview",
    "routes:generate": "tsr generate",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,md,css}\"",
    "check-types": "tsr generate && tsc --noEmit",
    "codegen": "graphql-codegen --config codegen.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@phosphor-icons/react": "^2.1.10",
    "@repo/api": "workspace:*",
    "@repo/ui": "workspace:*",
    "@tanstack/react-query": "^5.100.11",
    "@tanstack/react-router": "^1.114.29",
    "@tanstack/react-table": "^8.21.3",
    "@uidotdev/usehooks": "^2.4.1",
    "class-variance-authority": "^0.7.1",
    "country-flag-icons": "^1.6.17",
    "date-fns": "^4.2.1",
    "i18next": "26.3.1",
    "i18next-browser-languagedetector": "^8.2.0",
    "i18next-icu": "^2.4.1",
    "radix-ui": "^1.4.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.76.0",
    "react-i18next": "^15.7.4",
    "tailwindcss": "^4.3.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^7.0.0",
    "@graphql-codegen/client-preset": "^6.0.0",
    "@graphql-typed-document-node/core": "^3.2.0",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@tanstack/router-cli": "^1.167.17",
    "@tanstack/router-plugin": "^1.114.29",
    "@types/node": "^25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "10.4.1",
    "graphql": "^16.14.0",
    "typescript": "6.0.3",
    "vite": "8.0.16"
  }
}
