# Public web app URL (OAuth redirects, canonical origin)
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Nest API origin (GraphQL: {NEXT_PUBLIC_API_URL}/graphql)
NEXT_PUBLIC_API_URL=http://localhost:3000

# OAuth client IDs for /auth/yandex and /auth/google (secrets only on API)
# YANDEX_CLIENT_ID=
# GOOGLE_CLIENT_ID=
