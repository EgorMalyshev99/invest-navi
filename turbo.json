{
  "$schema": "https://turborepo.dev/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "globalEnv": [
    "NODE_ENV",
    "LANDING_URL",
    "DASHBOARD_URL",
    "NEXT_PUBLIC_APP_URL",
    "NEXT_PUBLIC_DASHBOARD_URL",
    "NEXT_PUBLIC_API_URL",
    "VITE_APP_URL",
    "VITE_API_URL",
    "YANDEX_CLIENT_ID",
    "YANDEX_CLIENT_SECRET",
    "NEXT_PUBLIC_YANDEX_CLIENT_ID",
    "VITE_YANDEX_CLIENT_ID",
    "GOOGLE_CLIENT_ID",
    "GOOGLE_CLIENT_SECRET",
    "NEXT_PUBLIC_GOOGLE_CLIENT_ID",
    "VITE_GOOGLE_CLIENT_ID",
    "VERCEL_URL",
    "PORT",
    "VERCEL",
    "DATABASE_URL",
    "JWT_SECRET",
    "JWT_REFRESH_SECRET",
    "AI_PROVIDER",
    "GROQ_API_KEY",
    "GEMINI_API_KEY",
    "OPENROUTER_API_KEY",
    "TINKOFF_TOKEN"
  ],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {},
    "check-types": {
      "dependsOn": ["^build"]
    },
    "codegen": {
      "outputs": ["src/shared/api/graphql/generated/**"]
    }
  }
}
