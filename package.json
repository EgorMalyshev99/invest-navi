{
  "name": "invest-navi",
  "version": "0.0.1",
  "private": true,
  "description": "ИнвестНавигатор — AI-платформа для частных инвесторов на российском рынке",
  "author": "",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "api:build": "turbo run build --filter=api",
    "api:dev": "turbo run dev --filter=api",
    "api:lint": "turbo run lint --filter=api",
    "landing:build": "turbo run build --filter=landing",
    "landing:dev": "turbo run dev --filter=landing",
    "landing:lint": "turbo run lint --filter=landing",
    "dashboard:build": "turbo run build --filter=dashboard",
    "dashboard:dev": "turbo run dev --filter=dashboard",
    "dashboard:lint": "turbo run lint --filter=dashboard",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,md,css}\""
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "turbo": "^2.9.16"
  },
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=22"
  }
}
